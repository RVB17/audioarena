# ===========================
# AudioArena .gitignore
# SECURITY: This repo is PUBLIC — never commit secrets
# ===========================

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ===========================
# SECRETS & ENVIRONMENT FILES
# ===========================
# CRITICAL: Never commit these to a public repo
.env
.env.*
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
!.env.local.example

# Supabase local config (may contain keys)
supabase/.temp/
supabase/.branches/
supabase/config.toml

# Private keys and certificates
*.pem
*.key
*.cert
*.p12
*.pfx
*.jks

# ===========================
# BUILD & OUTPUT
# ===========================
# Next.js
/.next/
/out/
/build
/.swc/

# Production
/dist

# ===========================
# TESTING & COVERAGE
# ===========================
/coverage
*.lcov
.nyc_output

# ===========================
# OS FILES
# ===========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ===========================
# EDITOR & IDE
# ===========================
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ===========================
# DEBUG & LOGS
# ===========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ===========================
# DEPLOYMENT
# ===========================
.vercel
.netlify

# ===========================
# TYPESCRIPT
# ===========================
*.tsbuildinfo
next-env.d.ts

# ===========================
# AUDIO & MEDIA (large files)
# ===========================
# SoundFont files (too large for git — use Git LFS or download script)
public/soundfonts/*.sf2
public/soundfonts/*.sf3

# User uploads (should never be in repo)
/uploads
/tmp
