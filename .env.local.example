# ===========================
# AudioArena Environment Variables
# ===========================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git — it contains secrets
# ===========================

# Supabase
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# NOTE: NEXT_PUBLIC_ vars are exposed to the browser.
# The anon key is safe to expose — it's used with Row Level Security (RLS).
# NEVER put the service_role key in a NEXT_PUBLIC_ variable.

# Server-only Supabase key (for admin operations, never exposed to browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
